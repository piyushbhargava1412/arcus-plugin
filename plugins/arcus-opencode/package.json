{
  "name": "arcus-opencode",
  "version": "2.0.0",
  "description": "ARCUS (Spec → Code → Pull Request pipeline) as an OpenCode plugin. Bundles the ARCUS skills, agents, and helper scripts and stages them into the target repository at session start.",
  "type": "module",
  "license": "MIT",
  "author": "Krill",
  "homepage": "https://github.com/piyushbhargava1412/arcus-plugin/tree/main/plugins/arcus-opencode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piyushbhargava1412/arcus-plugin.git",
    "directory": "plugins/arcus-opencode"
  },
  "bugs": {
    "url": "https://github.com/piyushbhargava1412/arcus-plugin/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "arcus",
    "spec-driven-development",
    "sdd",
    "tdd",
    "agentic-ai"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bundled"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "build": "node scripts/sync-version.mjs && node scripts/build-bundle.mjs && node scripts/build-plugin.mjs",
    "prepack": "node scripts/sync-version.mjs && node scripts/build-bundle.mjs && node scripts/build-plugin.mjs"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.11",
    "esbuild": "^0.28.1"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
